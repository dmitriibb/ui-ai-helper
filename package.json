{
  "name": "ui-ai-helper",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "dev:mcp": "npm run dev --workspace=packages/mcp-server",
    "build:mcp": "npm run build --workspace=packages/mcp-server",
    "build": "npm run build:desktop && npm run build:mcp"
  }
}
