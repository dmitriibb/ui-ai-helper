{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UI AI Helper",
  "version": "0.1.0",
  "identifier": "com.ui-ai-helper.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "UI AI Helper",
        "width": 900,
        "height": 650,
        "minWidth": 320,
        "minHeight": 220,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
